      <div class="leg-item"><div class="leg-dot" style="background:#2d5c3e"></div>ジブリパーク（長久手）</div>
      <div class="leg-item"><div class="leg-dot" style="background:#7a5500"></div>ホテル（金山）</div>
    </div>
  </div>

  <!-- INTEGRATED GHIBLI DETAIL -->

<div class="ghibli-integration">
<style>

.ghibli-integration{
–forest:#2d5a27;–forest2:#4a7c3f;–leaf:#7ab648;
–cream:#faf6ed;–warm:#fff9f0;–gold:#d97706;
–majo:#7c3aed;–majo2:#a78bfa;–majo3:#ede9fe;
–souko:#c2410c;–souko2:#fb923c;–souko3:#fff7ed;
–mono:#15803d;–mono2:#4ade80;–mono3:#f0fdf4;
–dondo:#1d4ed8;–dondo2:#60a5fa;–dondo3:#eff6ff;
–gray:#6b7280;–shadow:rgba(0,0,0,0.13);
}
*{box-sizing:border-box;margin:0;padding:0}

/* HEADER */
.hdr{
background:linear-gradient(135deg,var(–forest) 0%,var(–forest2) 60%,#3d6b32 100%);
padding:18px 16px 14px;text-align:center;position:relative;overflow:hidden
}
.hdr::after{content:’’;position:absolute;inset:0;
background:radial-gradient(circle at 20% 50%,rgba(255,255,255,0.06) 0%,transparent 60%);
pointer-events:none}
.hdr h1{font-size:20px;font-weight:700;color:#fff;letter-spacing:.06em;text-shadow:0 2px 6px rgba(0,0,0,.3);position:relative}
.hdr-sub{font-size:11px;color:rgba(255,255,255,.8);margin-top:4px;letter-spacing:.08em;position:relative}
.hdr-chips{display:flex;justify-content:center;gap:6px;flex-wrap:wrap;margin-top:10px;position:relative}
.chip{background:rgba(255,255,255,.15);border:1px solid rgba(255,255,255,.28);color:#fff;
font-size:10px;padding:3px 10px;border-radius:20px;letter-spacing:.04em}

/* MAIN */
.wrap{max-width:820px;margin:0 auto;padding:14px 14px 30px}

/* SECTION CARD */
.card{background:#fff;border-radius:14px;overflow:hidden;box-shadow:0 3px 16px var(–shadow);margin-bottom:14px}
.card-head{padding:9px 14px;display:flex;align-items:center;gap:7px;font-weight:700;font-size:13px;color:#fff}

/* ===================== MAP ===================== */
.map-wrap{position:relative;width:100%;background:#e8f5e9}
.map-wrap img{width:100%;height:auto;display:block}
.map-svg{position:absolute;top:0;left:0;width:100%;height:100%;overflow:visible}

/* SVGのクリック可能な要素 */
.area-btn{cursor:pointer;transition:filter .2s}
.area-btn:hover circle{filter:brightness(1.15)}

/* TOOLTIP */
.tt{
display:none;position:absolute;z-index:200;
background:#fff;border-radius:12px;box-shadow:0 8px 30px rgba(0,0,0,.22);
width:240px;padding:0;overflow:hidden;
animation:ttIn .2s ease
}
.tt.open{display:block}
@keyframes ttIn{from{opacity:0;transform:scale(.9) translateY(6px)}to{opacity:1;transform:scale(1) translateY(0)}}
.tt-head{padding:10px 12px;font-size:13px;font-weight:700;color:#fff;display:flex;align-items:center;justify-content:space-between}
.tt-close{background:rgba(255,255,255,.2);border:none;color:#fff;width:22px;height:22px;border-radius:50%;cursor:pointer;font-size:12px}
.tt-body{padding:10px 12px}
.tt-time{display:inline-flex;align-items:center;gap:4px;background:#f3f4f6;padding:3px 8px;border-radius:12px;font-weight:700;font-size:10px;margin-bottom:8px}
.tt-spots h4{font-size:10px;color:#888;letter-spacing:.07em;text-transform:uppercase;margin-bottom:4px}
.tt-spot{display:flex;gap:6px;padding:3px 0;border-bottom:1px solid #f5f5f5;align-items:flex-start}
.tt-spot-t{min-width:38px;font-size:10px;font-weight:700;color:#999;padding-top:1px}
.tt-note{background:#fffbe6;border-left:2px solid var(–gold);padding:6px 8px;border-radius:0 6px 6px 0;font-size:10px;line-height:1.6;color:#555;margin-top:8px}

/* LEGEND */
.legend{padding:10px 14px;display:flex;flex-wrap:wrap;gap:8px;background:var(–warm);border-top:1px solid #f0ebe0}
.leg{display:flex;align-items:center;gap:5px;font-size:11px;color:#444}
.leg-dot{width:13px;height:13px;border-radius:50%;border:2px solid #fff;box-shadow:0 1px 3px rgba(0,0,0,.2);
font-size:8px;display:flex;align-items:center;justify-content:center;color:#fff;font-weight:700;flex-shrink:0}

/* ===================== MOVE DIAGRAM ===================== */
.move-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px}
@media(max-width:500px){.move-grid{grid-template-columns:1fr}}
.move-item{display:flex;align-items:center;gap:8px;padding:8px 10px;background:#f9f9f9;border-radius:10px;font-size:12px}
.move-from,.move-to{font-weight:700;font-size:11px;padding:3px 8px;border-radius:8px;color:#fff;white-space:nowrap}
.move-mid{display:flex;flex-direction:column;align-items:center;flex:1;min-width:0}
.move-arrow{color:#999;font-size:16px;line-height:1}
.move-info{font-size:10px;color:#666;text-align:center;font-weight:600;white-space:nowrap}

/* ===================== SCHEDULE ===================== */
.sch-row{display:flex;gap:8px;padding:5px 0;border-bottom:1px solid #f0ebe0;align-items:flex-start;font-size:12px}
.sch-time{min-width:48px;font-weight:700;font-size:11px;color:#666;padding-top:2px;flex-shrink:0}
.sch-badge{display:inline-flex;align-items:center;gap:3px;padding:2px 8px;border-radius:12px;font-size:10px;font-weight:700;color:#fff;margin-right:5px;white-space:nowrap;flex-shrink:0}
.sch-content{line-height:1.5}
.sch-spots{margin-top:4px;padding-left:4px;font-size:11px;color:#666;line-height:1.6}
.sch-spots li{list-style:none;padding-left:12px;position:relative}
.sch-spots li::before{content:’›’;position:absolute;left:0;color:#999}

/* AREA INFO CARDS */
.area-cards{display:grid;grid-template-columns:1fr 1fr;gap:10px}
@media(max-width:560px){.area-cards{grid-template-columns:1fr}}
.acard{border-radius:12px;overflow:hidden;box-shadow:0 2px 10px var(–shadow)}
.acard-head{padding:8px 12px;font-size:12px;font-weight:700;color:#fff}
.acard-body{padding:10px 12px;font-size:12px;line-height:1.9;color:#555}
.acard-body ul{list-style:none;padding:0}
.acard-body li{padding-left:14px;position:relative}
.acard-body li::before{content:‘🔸’;position:absolute;left:0;font-size:9px;top:2px}
.acard-stay{display:inline-block;padding:2px 8px;border-radius:10px;font-size:10px;font-weight:700;color:#fff;margin-bottom:6px}

/* NOTE BOX */
.note-box{padding:10px 12px;background:#fffbe6;border-left:3px solid var(–gold);border-radius:0 8px 8px 0;font-size:11px;line-height:1.7;color:#555;margin-top:10px}
.note-box strong{color:#c05621}

/* FOOTER */
.footer{text-align:center;font-size:10px;color:#aaa;padding-bottom:12px}

