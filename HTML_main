<script>
function showTT(id, e) {
  document.querySelectorAll('.tt').forEach(t => t.classList.remove('open'));
  const tt = document.getElementById('tt-' + id);
  if (!tt) return;
  const wrap = document.getElementById('mapWrap');
  const img = document.getElementById('mapImg');
  const scaleX = img.offsetWidth / 670;
  const scaleY = img.offsetHeight / 447;
  const coords = {majo:[448,258],souko:[200,310],mono:[508,120],dondo:[533,360]};
  const [cx,cy] = coords[id];
  let left = cx * scaleX + wrap.offsetLeft - 120;
  let top  = cy * scaleY + wrap.offsetTop  + 30;
  left = Math.max(4, Math.min(left, window.innerWidth - 248));
  top  = Math.max(4, top);
  tt.style.left = left + 'px';
  tt.style.top  = top  + 'px';
  tt.style.position = 'fixed';
  tt.classList.add('open');
  e && e.stopPropagation();
}
function closeTT(id) {
  const tt = document.getElementById('tt-' + id);
  if (tt) tt.classList.remove('open');
}
document.addEventListener('click', function(e) {
  if (!e.target.closest('.tt') && !e.target.closest('.area-btn')) {
    document.querySelectorAll('.tt').forEach(t => t.classList.remove('open'));
  }
});
</script>

